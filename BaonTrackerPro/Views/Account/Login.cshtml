@model BaonTrackerPro.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Log In";
    Layout = "_AuthLayout";
}

<style>
    :root{
        --brand: #27AA83;
        --brand-2: #6ED0B6;
        --brand-3: #AEE6D8;
        --text: #1e1e1e;
        --muted: #7a7a7a;
        --border: rgba(39,170,131,0.45);
    }

    .auth-shell{
        min-height: 100vh;
        display:flex;
        background:#ffffff;
        font-family: "Inter", sans-serif;
    }

    .auth-left{
        width: 44%;
        min-width: 360px;
        padding: 34px 28px;
        background: var(--brand);
        border-top-right-radius: 34px;
        border-bottom-right-radius: 34px;
        position: relative;
        overflow: hidden;
        display:flex;
        flex-direction:column;
        justify-content:space-between;
        color:#fff;
    }

    .auth-left::before,
    .auth-left::after{
        content:"";
        position:absolute;
        top:0;
        bottom:0;
        width: 54%;
        border-top-right-radius: 34px;
        border-bottom-right-radius: 34px;
        right:-14%;
    }

    .auth-left::before{
        background: rgba(255,255,255,0.20);
        transform: translateX(0);
    }
    .auth-left::after{
        background: rgba(255,255,255,0.14);
        right:-28%;
    }

    .brand{
        position:relative;
        z-index:1;
        display:flex;
        align-items:flex-start;
        gap:12px;
    }
    .brand-mark{
        width: 44px;
        height: 44px;
        border-radius: 14px;
        background: rgba(255,255,255,0.14);
        display:flex;
        align-items:center;
        justify-content:center;
        flex-shrink:0;
        font-size: 22px;
    }
    .brand-text{
        line-height:1.05;
        margin-top: 2px;
    }
    .brand-text .name{
        font-weight: 800;
        font-size: 22px;
        letter-spacing: -0.3px;
    }
    .brand-text .pro{
        display:flex;
        align-items:center;
        gap:6px;
        margin-top: 4px;
        font-weight: 700;
        font-size: 12px;
        opacity: 0.95;
    }
    .tagline{
        position:relative;
        z-index:1;
        font-weight: 700;
        color: rgba(0,0,0,0.62);
        margin: 0;
        font-size: 16px;
    }

    .auth-right{
        flex:1;
        display:flex;
        align-items:center;
        justify-content:center;
        padding: 46px 22px;
    }

    .auth-card{
        width: 100%;
        max-width: 520px;
    }

    .auth-title{
        font-size: 40px;
        font-weight: 800;
        letter-spacing: -0.6px;
        margin-bottom: 6px;
        color: var(--text);
    }
    .auth-subtitle{
        color: var(--muted);
        margin-bottom: 22px;
        font-weight: 500;
    }

    .form-label{
        font-weight: 700;
        color: #2a2a2a;
        margin-bottom: 6px;
    }
    .form-control{
        border-radius: 10px;
        border: 2px solid var(--border);
        padding: 12px 12px;
        background: #fff;
    }
    .form-control:focus{
        border-color: var(--brand);
        box-shadow: 0 0 0 0.25rem rgba(39,170,131,0.18);
    }

    .input-with-icon{
        position: relative;
    }
    .input-with-icon .form-control{
        padding-right: 44px;
    }
    .toggle-visibility{
        position:absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: rgba(30,30,30,0.55);
        padding: 6px;
        border-radius: 10px;
        line-height: 0;
        cursor: pointer;
        transition: background .12s ease, color .12s ease;
    }
    .toggle-visibility:hover{
        background: rgba(39,170,131,0.10);
        color: rgba(30,30,30,0.75);
    }

    .pw-meter{
        display:flex;
        align-items:center;
        justify-content: space-between;
        gap: 10px;
        margin-top: 8px;
    }
    .pw-meter .label{
        font-weight: 800;
        color: rgba(0,0,0,0.55);
        font-size: 0.78rem;
        letter-spacing: 0.02em;
    }
    .pw-meter .pill{
        font-weight: 900;
        font-size: 0.75rem;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,0.08);
        background: rgba(0,0,0,0.04);
        color: rgba(0,0,0,0.55);
        min-width: 84px;
        text-align:center;
    }
    .pw-meter .pill.weak{
        background: rgba(220,53,69,0.10);
        border-color: rgba(220,53,69,0.25);
        color: #b02a37;
    }
    .pw-meter .pill.medium{
        background: rgba(245,158,11,0.12);
        border-color: rgba(245,158,11,0.28);
        color: #9a6200;
    }
    .pw-meter .pill.strong{
        background: rgba(39,170,131,0.12);
        border-color: rgba(39,170,131,0.28);
        color: #197a60;
    }

    .btn-auth{
        background: var(--brand);
        border: none;
        border-radius: 10px;
        padding: 12px 14px;
        width: 100%;
        font-weight: 800;
        color: #fff;
        margin-top: 10px;
        box-shadow: 0 10px 22px rgba(39,170,131,0.18);
        transition: transform .12s ease, box-shadow .12s ease, background .12s ease;
    }
    .btn-auth:hover{
        background:#239a76;
        transform: translateY(-1px);
        box-shadow: 0 14px 26px rgba(39,170,131,0.22);
        color:#fff;
    }

    .auth-footer{
        text-align:center;
        margin-top: 16px;
        color: #8a8a8a;
        font-weight: 600;
    }
    .auth-footer a{
        color: var(--brand);
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .validation-summary-errors{
        background: rgba(220,53,69,0.08);
        border: 1px solid rgba(220,53,69,0.35);
        color: #b02a37;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 14px;
        font-weight: 600;
    }

    .success-banner{
        background: rgba(39,170,131,0.10);
        border: 1px solid rgba(39,170,131,0.35);
        color: #197a60;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 14px;
        font-weight: 700;
    }
    .text-danger{
        font-weight: 600;
    }

    @@media (max-width: 900px){
        .auth-left{ display:none; }
        .auth-shell{ display:block; }
        .auth-right{
            min-height: 100vh;
            display:flex;
            align-items:center;
            justify-content:center;
            padding: 32px 18px;
        }
        .auth-card{ max-width: 560px; margin: 0 auto; }
        .auth-title{ font-size: 34px; }

        /* Must be !important because the base rule appears later in this <style>. */
        .auth-brand-top{ display:block !important; }
        .auth-card-brand{ display:none; }
    }

    /* 901px+ (desktop): hide the in-card logo */
    @@media (min-width: 901px){
        .auth-card-brand{ display:none; }
    }

    .auth-brand-top{
        display:none;
        margin-bottom: 14px;
    }
    /* Small-screen-only, centered & more visible brand mark */
    .auth-brand-top .brand{
        justify-content: center;
        text-align: center;
        margin: 0 auto 18px;
    }
    .auth-brand-top .brand-mark{
        font-size: 64px;
        width: 80px;
        height: 80px;
        border-radius: 24px;
    }
    .auth-brand-top .name{
        font-size: 28px;
    }
    .auth-brand-top .pro{
        font-size: 16px;
    }
</style>

<div class="auth-shell">
    <section class="auth-left" aria-hidden="true">
        <div class="brand">
            <div class="brand-mark">🐷</div>
            <div class="brand-text">
                <div class="name">BaonTracker</div>
                <div class="pro"><span>✨</span> <span>PRO</span></div>
            </div>
        </div>
        <p class="tagline">Kontrolado ang gastos, panalo sa ipon</p>
    </section>

    <section class="auth-right">
        <div class="auth-card">
            <div class="auth-brand-top" aria-hidden="true">
                <div class="brand">
                    <div class="brand-mark">🐷</div>
                    <div class="brand-text">
                        <div class="name">BaonTracker</div>
                        <div class="pro"><span>✨</span> <span>PRO</span></div>
                    </div>
                </div>
            </div>
            <div class="brand auth-card-brand" aria-hidden="true">
                <div class="brand-mark">🐷</div>
                <div class="brand-text">
                    <div class="name">BaonTracker</div>
                    <div class="pro"><span>✨</span> <span>PRO</span></div>
                </div>
            </div>
            <div class="auth-title">Welcome Back!</div>
            <div class="auth-subtitle">Login to your account</div>

            @if (!string.IsNullOrWhiteSpace(ViewBag.SuccessMessage as string))
            {
                <div class="success-banner">@ViewBag.SuccessMessage</div>
            }

            @Html.ValidationSummary(excludePropertyErrors: true)

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="mb-3">
                    <label class="form-label" asp-for="Email"></label>
                    <input class="form-control js-email"
                           asp-for="Email"
                           placeholder="mariasantos@gmail.com"
                           inputmode="email"
                           autocomplete="email"
                           spellcheck="false"
                           autocapitalize="none" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="mb-2">
                    <label class="form-label" asp-for="Password"></label>
                    <div class="input-with-icon">
                        <input class="form-control js-password"
                               asp-for="Password"
                               placeholder="8+ characters"
                               autocomplete="current-password" />
                        <button type="button" class="toggle-visibility js-toggle-password" aria-label="Show password">
                            <i class="iconoir-eye"></i>
                        </button>
                    </div>
                    <div class="pw-meter" aria-live="polite">
                        <div class="label">Password strength</div>
                        <div class="pill js-pw-strength">—</div>
                    </div>
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <button type="submit" class="btn-auth">Log In</button>
            </form>

            <div class="auth-footer">
                Don’t have an account? <a asp-controller="Account" asp-action="Register">Sign up</a>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function normalizeEmailInput(el) {
                if (!el) return;
                let v = el.value ?? '';
                v = v.replace(/\s+/g, '');
                v = v.replace(/^\.+/, '');
                el.value = v;
            }

            document.querySelectorAll('.js-email').forEach(el => {
                el.addEventListener('input', () => normalizeEmailInput(el));
                el.addEventListener('blur', () => normalizeEmailInput(el));
            });

            const pwd = document.querySelector('.js-password');
            const btn = document.querySelector('.js-toggle-password');
            if (pwd && btn) {
                btn.addEventListener('click', () => {
                    const isHidden = pwd.type === 'password';
                    pwd.type = isHidden ? 'text' : 'password';
                    btn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
                    btn.innerHTML = isHidden ? '<i class="iconoir-eye-closed"></i>' : '<i class="iconoir-eye"></i>';
                });
            }

            function computeStrength(pw) {
                const p = pw || '';
                let score = 0;
                if (p.length >= 8) score++;
                if (p.length >= 12) score++;
                if (/[a-z]/.test(p)) score++;
                if (/[A-Z]/.test(p)) score++;
                if (/\d/.test(p)) score++;
                if (/[^a-zA-Z0-9]/.test(p)) score++;

                if (p.length === 0) return { label: '—', cls: '' };
                if (score <= 2) return { label: 'Weak', cls: 'weak' };
                if (score <= 4) return { label: 'Medium', cls: 'medium' };
                return { label: 'Strong', cls: 'strong' };
            }

            const strengthEl = document.querySelector('.js-pw-strength');
            if (pwd && strengthEl) {
                const update = () => {
                    const s = computeStrength(pwd.value);
                    strengthEl.textContent = s.label;
                    strengthEl.classList.remove('weak', 'medium', 'strong');
                    if (s.cls) strengthEl.classList.add(s.cls);
                };
                pwd.addEventListener('input', update);
                update();
            }
        })();
    </script>
}

