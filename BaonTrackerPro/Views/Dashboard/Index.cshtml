@using BaonTrackerPro.Models
@model FinanceDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var today = DateTime.Now.ToString("dddd, MMMM dd, yyyy");
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --bg: #F6F9F8;
        --surface: #ffffff;
        --surface-alt: #f7f8f7;
        --border: #e4e7e4;
        --text-primary: #1a1d1a;
        --text-secondary: #6b7280;
        --text-muted: #9ca3af;
        --accent: #1a9f6e;
        --accent-light: #e6f7f1;
        --accent-dark: #137a54;
        --danger: #e53e3e;
        --danger-light: #fff5f5;
        --income-color: #1a9f6e;
        --expense-color: #e53e3e;
        --radius-sm: 10px;
        --radius-md: 14px;
        --radius-lg: 18px;
        --font: 'DM Sans', sans-serif;
        --font-mono: 'DM Mono', monospace;
    }

    .dashboard-wrapper {
        max-width: 100%;
        margin: 0;
        padding: 28px 20px 48px;
        background: #F6F9F8;
        min-height: 100vh;
        font-family: "Inter", sans-serif;
        color: var(--text-primary);
    }

    .dash-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 28px; gap: 16px; }
    .dash-header-left .section-label { font-size: 12px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2px; }
    .dash-header-left .date-text { font-size: 12px; color: var(--text-secondary); margin-bottom: 8px; }
    .dash-header-left h1 { font-size: 26px; font-weight: 600; color: var(--text-primary); letter-spacing: -.3px; }
    .btn-add { display: inline-flex; align-items: center; gap: 6px; background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm); padding: 10px 20px; font-family: "Inter", sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; white-space: nowrap; text-decoration: none; transition: background .15s; }
    .btn-add:hover { background: var(--accent-dark); color: #fff; }

    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px; }
    @@media (max-width: 640px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 16px; display: flex; flex-direction: column; gap: 8px; }
    .stat-card-top { display: flex; align-items: center; justify-content: space-between; }
    .stat-label { font-size: 11px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--text-muted); }
    .stat-icon { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .stat-icon.balance  { background: #e6f4ff; }
    .stat-icon.income   { background: var(--accent-light); }
    .stat-icon.expense  { background: #fff0f0; }
    .stat-icon.savings  { background: #fef3e2; }
    .stat-value { font-family: "Inter", sans-serif; font-size: 1.5rem; font-weight: 550; color: var(--text-primary); letter-spacing: -0.5px; display: flex; align-items: baseline; gap: 2px; transition: opacity .3s; }

    .mid-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    @@media (max-width: 580px) { .mid-grid { grid-template-columns: 1fr; } }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px; }
    .card-title { font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 16px; }

    .spending-inner { display: flex; align-items: center; gap: 20px; }
    .donut-wrap { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
    .cat-legend { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .cat-item { display: flex; align-items: center; gap: 6px; font-size: 13px; }
    .cat-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .cat-name { flex: 1; color: var(--text-secondary); }
    .cat-pct  { font-weight: 500; color: var(--text-primary); }

    .savings-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px 0; gap: 10px; color: var(--text-muted); }
    .savings-empty svg { opacity: .4; }
    .savings-empty p { font-size: 13px; }
    .goal-item { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .goal-header { display: flex; justify-content: space-between; font-size: 13px; }
    .goal-name { font-weight: 500; }
    .goal-amounts { color: var(--text-secondary); }
    .goal-bar { height: 6px; background: var(--bg); border-radius: 99px; overflow: hidden; }
    .goal-fill { height: 100%; background: var(--accent); border-radius: 99px; }

    .txn-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px; }
    .txn-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .txn-header a { font-size: 13px; font-weight: 500; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 3px; }
    .txn-list { display: flex; flex-direction: column; gap: 2px; }
    .txn-item { display: flex; align-items: center; gap: 12px; padding: 10px 8px; border-radius: var(--radius-sm); transition: background .1s; }
    .txn-item:hover { background: var(--surface-alt); }
    .txn-avatar { width: 38px; height: 38px; border-radius: 10px; background: var(--surface-alt); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 17px; flex-shrink: 0; }
    .txn-info { flex: 1; min-width: 0; }
    .txn-name { font-size: 14px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .txn-meta { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
    .txn-amount { font-family: "Inter", sans-serif; font-size: 14px; font-weight: 500; white-space: nowrap; display: flex; align-items: center; gap: 4px; }
    .txn-amount.income  { color: var(--income-color); }
    .txn-amount.expense { color: var(--expense-color); }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .txn-item.new { animation: slideIn .3s ease forwards; }
</style>

<div class="dashboard-wrapper">

    <div class="dash-header">
        <div class="dash-header-left">
            <div class="section-label">Dashboard</div>
            <div class="date-text">@today</div>
            <h1>Good Day, @Model.UserName!</h1>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Balance</span>
                <span class="stat-icon balance">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <rect x="1" y="4" width="14" height="10" rx="2" stroke="#3b82f6" stroke-width="1.5"/>
                        <path d="M1 7h14" stroke="#3b82f6" stroke-width="1.5"/>
                        <rect x="3" y="9" width="3" height="2" rx=".5" fill="#3b82f6"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value" id="statBalance">&#8369;@Model.Balance.ToString("N2")</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Income</span>
                <span class="stat-icon income">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3 11L8 5l5 6" stroke="#1a9f6e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value" id="statIncome">&#8369;@Model.Income.ToString("N2")</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Expenses</span>
                <span class="stat-icon expense">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3 5l5 6 5-6" stroke="#e53e3e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value" id="statExpenses">&#8369;@Model.Expenses.ToString("N2")</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Savings Goals</span>
                <span class="stat-icon savings">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <ellipse cx="8" cy="9" rx="6" ry="5" stroke="#f59e0b" stroke-width="1.5"/>
                        <path d="M5 5.5C5 4 6.5 2.5 8 2.5s3 1.5 3 3" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                        <path d="M10.5 8H14" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="12" cy="10" r=".75" fill="#f59e0b"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value" id="statSavings">&#8369;@Model.SavingsGoals.ToString("N2")</div>
        </div>
    </div>

    <div class="mid-grid">
        <div class="card">
            <div class="card-title">Spending by Category</div>

            <div id="spendingContainer">
                @if (Model.SpendingByCategory != null && Model.SpendingByCategory.Any())
                {
                    <div class="spending-inner">
                        <div class="donut-wrap">
                            <canvas id="donutChart"></canvas>
                        </div>
                        <div class="cat-legend">
                            @foreach (var cat in Model.SpendingByCategory)
                            {
                                <div class="cat-item">
                                    <span class="cat-dot" style="background: @cat.Color;"></span>
                                    <span>@cat.Icon</span>
                                    <span class="cat-name">@cat.Name</span>
                                    <span class="cat-pct">@cat.Percentage.ToString("0")%</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="savings-empty">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                            <circle cx="24" cy="24" r="20" stroke="#9ca3af" stroke-width="2"/>
                            <path d="M16 24h16M24 16v16" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <p>No spending data yet</p>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-title">Savings Goals</div>

            <div id="goalsContainer">
                @if (Model.Goals != null && Model.Goals.Any())
                {
                    @foreach (var goal in Model.Goals)
                    {
                        var pct = goal.TargetAmount > 0 ? (goal.CurrentAmount / goal.TargetAmount * 100) : 0;
                        <div class="goal-item">
                            <div class="goal-header">
                                <span class="goal-name">@goal.Name</span>
                                <span class="goal-amounts">&#8369;@goal.CurrentAmount.ToString("N0") / &#8369;@goal.TargetAmount.ToString("N0")</span>
                            </div>
                            <div class="goal-bar">
                                <div class="goal-fill" style="width: @pct.ToString("0")%;"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="savings-empty">
                        <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
                            <ellipse cx="28" cy="34" rx="18" ry="15" stroke="#9ca3af" stroke-width="2"/>
                            <path d="M17 17.5C17 13 21.5 9 28 9s11 4 11 8.5" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                            <path d="M38 29H46" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                            <circle cx="42" cy="34" r="2" fill="#9ca3af"/>
                            <path d="M24 34h8M28 30v8" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <p>No Savings Goals yet</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="txn-card">
        <div class="txn-header">
            <div class="card-title" style="margin-bottom:0;">Recent Transactions</div>
            <a href="/Transactions">View All
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
        </div>

        <div class="txn-list" id="txnList">
            @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
            {
                @foreach (var txn in Model.RecentTransactions)
                {
                    <div class="txn-item">
                        <div class="txn-avatar">@txn.CategoryIcon</div>
                        <div class="txn-info">
                            <div class="txn-name">@txn.Description</div>
                            <div class="txn-meta">@txn.Category · @txn.Date.ToString("MMM dd")</div>
                        </div>
                        <div class="txn-amount @(txn.IsIncome ? "income" : "expense")">
                            @if (txn.IsIncome)
                            {
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                    <path d="M2 8L6 3l4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span>+ &#8369;@txn.Amount.ToString("N2")</span>
                            }
                            else
                            {
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                    <path d="M2 4l4 5 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span>- &#8369;@txn.Amount.ToString("N2")</span>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="savings-empty" id="emptyState">
                    <p>No transactions yet</p>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
    let donutChartInstance = null;

    function formatNumber(n) {
        return Number(n).toLocaleString('en-PH', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    function escapeHtml(str) {
        const d = document.createElement('div');
        d.appendChild(document.createTextNode(str ?? ''));
        return d.innerHTML;
    }

    function fadeUpdate(id, value) {
        const el = document.getElementById(id);
        if (!el) return;
        el.style.opacity = '0';
        setTimeout(() => {
            el.textContent = value;
            el.style.opacity = '1';
        }, 200);
    }

    function updateStats(data) {
        fadeUpdate('statBalance',  '₱' + formatNumber(data.balance));
        fadeUpdate('statIncome',   '₱' + formatNumber(data.income));
        fadeUpdate('statExpenses', '₱' + formatNumber(data.expenses));
        fadeUpdate('statSavings',  '₱' + formatNumber(data.savingsGoals));
    }

    function renderTransactions(transactions) {
        const list = document.getElementById('txnList');
        if (!list) return;

        if (!transactions || transactions.length === 0) {
            list.innerHTML = `
                <div class="savings-empty" id="emptyState">
                    <p>No transactions yet</p>
                </div>`;
            return;
        }

        const arrowUp   = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 8L6 3l4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        const arrowDown = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 5 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

        list.innerHTML = transactions.map(txn => {
            const amountClass = txn.isIncome ? 'income' : 'expense';
            const sign  = txn.isIncome ? '+ ₱' : '- ₱';
            const arrow = txn.isIncome ? arrowUp : arrowDown;
            return `
                <div class="txn-item">
                    <div class="txn-avatar">${txn.categoryIcon}</div>
                    <div class="txn-info">
                        <div class="txn-name">${escapeHtml(txn.description)}</div>
                        <div class="txn-meta">${escapeHtml(txn.category)} · ${txn.date}</div>
                    </div>
                    <div class="txn-amount ${amountClass}">
                        ${arrow}
                        <span>${sign}${formatNumber(txn.amount)}</span>
                    </div>
                </div>`;
        }).join('');
    }

    function renderGoals(goals) {
        const container = document.getElementById('goalsContainer');
        if (!container) return;

        if (!goals || goals.length === 0) {
            container.innerHTML = `
                <div class="savings-empty">
                    <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
                        <ellipse cx="28" cy="34" rx="18" ry="15" stroke="#9ca3af" stroke-width="2"/>
                        <path d="M17 17.5C17 13 21.5 9 28 9s11 4 11 8.5" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                        <path d="M38 29H46" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="42" cy="34" r="2" fill="#9ca3af"/>
                        <path d="M24 34h8M28 30v8" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    <p>No Savings Goals yet</p>
                </div>`;
            return;
        }

        container.innerHTML = goals.map(goal => {
            const pct = goal.targetAmount > 0
                ? (goal.currentAmount / goal.targetAmount) * 100
                : 0;
            return `
                <div class="goal-item">
                    <div class="goal-header">
                        <span class="goal-name">${escapeHtml(goal.name)}</span>
                        <span class="goal-amounts">₱${Number(goal.currentAmount).toLocaleString('en-PH', { maximumFractionDigits: 0 })} / ₱${Number(goal.targetAmount).toLocaleString('en-PH', { maximumFractionDigits: 0 })}</span>
                    </div>
                    <div class="goal-bar">
                        <div class="goal-fill" style="width: ${pct.toFixed(0)}%;"></div>
                    </div>
                </div>`;
        }).join('');
    }

    function renderSpending(spendingByCategory) {
        const container = document.getElementById('spendingContainer');
        if (!container) return;

        if (!spendingByCategory || spendingByCategory.length === 0) {
            container.innerHTML = `
                <div class="savings-empty">
                    <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                        <circle cx="24" cy="24" r="20" stroke="#9ca3af" stroke-width="2"/>
                        <path d="M16 24h16M24 16v16" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    <p>No spending data yet</p>
                </div>`;
            if (donutChartInstance) {
                donutChartInstance.destroy();
                donutChartInstance = null;
            }
            return;
        }

        container.innerHTML = `
            <div class="spending-inner">
                <div class="donut-wrap"><canvas id="donutChart"></canvas></div>
                <div class="cat-legend">
                    ${spendingByCategory.map(cat => `
                        <div class="cat-item">
                            <span class="cat-dot" style="background: ${cat.color};"></span>
                            <span>${cat.icon}</span>
                            <span class="cat-name">${escapeHtml(cat.name)}</span>
                            <span class="cat-pct">${Number(cat.percentage).toFixed(0)}%</span>
                        </div>`).join('')}
                </div>
            </div>`;

        const donutCanvas = document.getElementById('donutChart');
        if (!donutCanvas) return;

        if (donutChartInstance) {
            donutChartInstance.destroy();
        }

        donutChartInstance = new Chart(donutCanvas, {
            type: 'doughnut',
            data: {
                labels: spendingByCategory.map(c => c.name),
                datasets: [{
                    data: spendingByCategory.map(c => c.percentage),
                    backgroundColor: spendingByCategory.map(c => c.color),
                    borderWidth: 3,
                    borderColor: '#fff',
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '68%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ' ' + ctx.label + ': ' + ctx.parsed + '%'
                        }
                    }
                }
            }
        });
    }

    async function refreshDashboard() {
        try {
            const response = await fetch('/Dashboard/GetDashboardData', {
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) {
                throw new Error('Failed to fetch dashboard data');
            }

            const data = await response.json();

            updateStats(data);
            renderTransactions(data.recentTransactions);
            renderGoals(data.goals);
            renderSpending(data.spendingByCategory);
        } catch (error) {
            console.error('Dashboard refresh error:', error);
        }
    }

    function combineDashboardDateTime() {
        const datePicker = document.getElementById('DatePicker');
        const timePicker = document.getElementById('TimePicker');
        const hiddenDate = document.getElementById('Date');

        if (!datePicker || !hiddenDate) return;

        const dateValue = datePicker.value;
        const timeValue = timePicker && timePicker.value ? timePicker.value : "00:00";

        if (dateValue) {
            hiddenDate.value = `${dateValue}T${timeValue}`;
        }
    }

    async function submitTransaction() {
        const btn = document.querySelector('#addTransactionForm .add-transaction-btn');
        if (!btn) return;

        btn.disabled = true;
        btn.textContent = 'Saving...';

        combineDashboardDateTime();

        const form = document.getElementById('addTransactionForm');
        const formData = new FormData(form);

        const transactionType = document.getElementById('TransactionType')?.value || 'expense';
        formData.set('IsIncome', transactionType === 'income');

        try {
            const resp = await fetch('/Dashboard/AddTransaction', {
                method: 'POST',
                body: formData
            });

            if (!resp.ok) throw new Error('Server error ' + resp.status);

            const data = await resp.json();

            if (data.success) {
                const modalEl = document.getElementById('addTransactionModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                if (modal) modal.hide();

                form.reset();

                document.getElementById('Date') && (document.getElementById('Date').value = '');
                document.getElementById('DatePicker') && (document.getElementById('DatePicker').value = '');
                document.getElementById('TimePicker') && (document.getElementById('TimePicker').value = '');

                const transactionTypeInput = document.getElementById('TransactionType');
                if (transactionTypeInput) transactionTypeInput.value = 'expense';

                document.querySelectorAll('.segmented-option').forEach(x => x.classList.remove('active'));
                const expenseOption = document.querySelector('.segmented-option[data-type="expense"]');
                if (expenseOption) expenseOption.classList.add('active');

                await refreshDashboard();
            } else {
                alert('Something went wrong. Please try again.');
            }
        } catch (err) {
            console.error(err);
            alert('Could not save transaction. Check your connection and try again.');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Add Transaction';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        refreshDashboard();

        const form = document.getElementById('addTransactionForm');
        if (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                submitTransaction();
            });
        }
    });

    document.addEventListener('shown.bs.modal', function (event) {
        if (event.target && event.target.id === 'addTransactionModal') {
            const now = new Date();

            const datePicker = document.getElementById('DatePicker');
            const timePicker = document.getElementById('TimePicker');

            if (datePicker && !datePicker.value) {
                datePicker.value = now.toISOString().split('T')[0];
            }

            if (timePicker && !timePicker.value) {
                const hours = String(now.getHours()).padStart(2, '0');
                const minutes = String(now.getMinutes()).padStart(2, '0');
                timePicker.value = `${hours}:${minutes}`;
            }
        }
    });
</script>