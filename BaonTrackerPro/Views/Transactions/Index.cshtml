@model IEnumerable<BaonTrackerPro.Models.Transaction>

@{
    ViewData["Title"] = "Transactions";
    var searchString = ViewData["CurrentFilter"] as string;
}

<div class="transactions-container">
    <div class="transactions-header">
        <h2>Transactions</h2>
        <p>@Model.Count() Transactions</p>
    </div>

    <div class="search-box mb-4">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@searchString" 
                   placeholder="Search Transactions" class="form-control me-2" />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Clear</a>
            }
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No transactions found.</div>
    }
    else
    {
        // Group transactions by date (using the date part only)
        var grouped = Model.GroupBy(t => t.Date.Date).OrderByDescending(g => g.Key);

        foreach (var group in grouped)
        {
            <div class="transaction-group mb-4">
                <h4 class="group-date">@group.Key.ToString("dddd, MMMM d, yyyy")</h4>
                @foreach (var transaction in group)
                {
                    <div class="transaction-item card mb-2">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div class="transaction-info d-flex align-items-center">
                                <i class="iconoir-shopping-cart transaction-icon me-3" style="font-size: 1.5rem;"></i>
                                <div>
                                    <h5 class="mb-0">@transaction.Description</h5>
                                    <small class="text-muted">@transaction.Category - @transaction.Date.ToString("MMM dd")</small>
                                </div>
                            </div>
                            <div class="transaction-amount d-flex align-items-center gap-3">
                                <span class="fw-bold @(transaction.Amount >= 0 ? "text-success" : "text-danger")">
                                    @(transaction.Amount >= 0 ? "+" : "-") ₱ @Math.Abs(transaction.Amount).ToString("N2")
                                </span>
                                <div class="actions">
                                    <a asp-action="Edit" asp-route-id="@transaction.Id" class="text-primary me-2" title="Edit">
                                        <i class="iconoir-edit-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@transaction.Id" class="text-danger" title="Delete">
                                        <i class="iconoir-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }

    <div class="mt-3">
        <a asp-action="Create" class="btn btn-primary">Add New Transaction</a>
    </div>
</div>

@section Scripts {
    <style>
        .transactions-container {
            max-width: 800px;
            margin: 0 auto;
        }
        .transactions-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .transactions-header h2 {
            margin-bottom: 0.5rem;
        }
        .group-date {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 1rem;
            border-left: 4px solid #27AA83;
            padding-left: 10px;
        }
        .transaction-item {
            border: none;
            border-bottom: 1px solid #e9ecef;
            border-radius: 0;
            background-color: transparent;
        }
        .transaction-item .card-body {
            padding: 1rem 0.5rem;
        }
        .transaction-icon {
            color: #6c757d;
        }
        .actions i {
            font-size: 1.2rem;
            cursor: pointer;
        }
        .actions a {
            text-decoration: none;
        }
    </style>
}