@model IEnumerable<BaonTrackerPro.Models.Transaction>

@{
    ViewData["Title"] = "Transactions";
    var searchString = ViewData["CurrentFilter"] as string;
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="transactions-page">
    @Html.AntiForgeryToken()
    <!-- Header -->
    <div class="header-row">
        <div class="title-section">
            <h1>Transactions</h1>
            <p>@Model.Count() Transactions</p>
        </div>
        <div class="add-button">
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addTransactionModal">
                <i class="iconoir-plus"></i>Add Transaction
            </button>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="search-filter-row">
        <form asp-action="Index" method="get" class="search-form">
            <div class="d-flex align-items-center gap-2">
                <div class="input-group" style="height: 36px;">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary-subtle"
                          style="height: 36px;">
                        <i class="iconoir-search text-secondary"></i>
                    </span>
                    <input type="text" name="searchString" value="@searchString"
                           class="form-control border-start-0 ps-0 border-secondary-subtle text-secondary"
                           placeholder="Search Transactions"
                           style="height: 36px; color: var(--bs-secondary-color) !important;" />
                </div>
            </div>
        </form>
        <div class="filter-dropdown">
            @{
                var currentType = ViewData["CurrentType"] as string ?? "";
                var currentSearch = ViewData["CurrentFilter"] as string ?? "";
            }
            <div class="dropdown">
                <button class="budget-filter-btn" type="button" data-bs-toggle="dropdown">
                    <i class="iconoir-filter"></i>
                    <span>@(string.IsNullOrEmpty(currentType) ? "All Types" : currentType)</span>
                    <i class="iconoir-nav-arrow-down"></i>
                </button>
                <ul class="dropdown-menu">
                    <li>
                        <a class="dropdown-item @(currentType == "" ? "selected" : "")"
                           href="?searchString=@currentSearch">All Types</a>
                    </li>
                    <li>
                        <a class="dropdown-item @(currentType == "Income" ? "selected" : "")"
                           href="?searchString=@currentSearch&type=Income">Income</a>
                    </li>
                    <li>
                        <a class="dropdown-item @(currentType == "Expense" ? "selected" : "")"
                           href="?searchString=@currentSearch&type=Expense">Expense</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Transaction List -->
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="iconoir-wallet" style="font-size: 3rem; color: #adb5bd;"></i>
            <p>No transactions yet. Add your first transaction!</p>
        </div>
    }
    else
    {
        <partial name="_TransactionList" model="Model" />
    }
</div>

<!-- Modal Partial -->
<partial name="_AddTransactionModal" />
<partial name="_DeleteConfirmationModal" />
@section Scripts {
    <script src="~/js/transactions.js"></script>
}