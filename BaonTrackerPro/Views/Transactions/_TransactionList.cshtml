@model IEnumerable<BaonTrackerPro.Models.Transaction>

@{
    var grouped = Model.GroupBy(t => t.Date.Date).OrderByDescending(g => g.Key);
}

@foreach (var group in grouped)
{
    <div class="date-group">
        <h3 class="date-label">@group.Key.ToString("dddd, MMMM d, yyyy")</h3>
        <div class="transaction-card">
            @foreach (var transaction in group)
            {
                var emoji = "🛒";
                if (transaction.Category?.ToLower().Contains("transport") == true)
                    emoji = "🚙";
                else if (transaction.Category?.ToLower().Contains("food") == true)
                    emoji = "🍔";
                else if (transaction.Category?.ToLower().Contains("personal") == true)
                    emoji = "👗";
                else if (transaction.Category?.ToLower().Contains("bills") == true)
                    emoji = "📄";
                else if (transaction.Category?.ToLower().Contains("entertainment") == true)
                    emoji = "🎮";
                else if (transaction.Category?.ToLower().Contains("education") == true)
                    emoji = "📚";
                else if (transaction.Category?.ToLower().Contains("health") == true)
                    emoji = "💊";
                else if (transaction.Category?.ToLower().Contains("allowance") == true ||
                         transaction.Description?.ToLower().Contains("allowance") == true)
                    emoji = "💰";

                var isPositive = transaction.Amount >= 0;
                var amountClass = isPositive ? "positive-amount" : "negative-amount";
                var arrowIcon = isPositive ? "iconoir-arrow-up" : "iconoir-arrow-down";

                <div class="transaction-row">
                    <div class="icon-bg @(isPositive ? "income-bg" : "expense-bg")">
                        <span class="emoji">@emoji</span>
                    </div>
                    <div class="transaction-details">
                        <div class="title">@transaction.Description</div>
                        <div class="subtitle">@transaction.Category · @transaction.Date.ToString("MMM dd")</div>
                    </div>
                    <div class="transaction-amount">
                        <span class="@amountClass">
                            <i class="@arrowIcon"></i>
                            @(isPositive ? "+" : "-") ₱ @Math.Abs(transaction.Amount).ToString("N2")
                        </span>
                    </div>
                    <div class="actions">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="javascript:void(0)"
                                           onclick="editTransaction(@transaction.Id)">
                                        <i class="iconoir-edit-pencil"></i> Edit
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="javascript:void(0)" onclick="showDetails(@transaction.Id)">
                                        <i class="iconoir-info-circle"></i> Details
                                    </a>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <a class="dropdown-item text-danger" href="javascript:void(0)"
                                           onclick="showDeleteModal(@transaction.Id)">
                                        <i class="iconoir-trash"></i> Delete
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <!-- Details Modal -->
    <div id="detailsModal" style="
        display:none;
        position:fixed;
        inset:0;
        background:rgba(0,0,0,0.4);
        z-index:9999;
        align-items:center;
        justify-content:center;">
        <div style="
            background:white;
            border-radius:24px;
            box-shadow:0 8px 32px rgba(0,0,0,0.12);
            padding:2rem;
            max-width:480px;
            width:90%;
            position:relative;">

            <!-- Close button -->
            <button onclick="closeDetails()" style="
                position:absolute;
                top:1rem; right:1rem;
                background:none;
                border:none;
                font-size:1.2rem;
                cursor:pointer;
                color:#6c757d;
                line-height:1;">
                <i class="iconoir-xmark"></i>
            </button>

            <!-- Title -->
            <h2 id="modal-description" style="font-size:1.5rem; font-weight:700; margin-bottom:0.25rem; color:#1e1e1e;">
            </h2>
            <p id="modal-category" style="font-size:1rem; color:#6c757d; margin-bottom:1rem;"></p>
            <div id="modal-badge" style="margin-bottom:1.5rem;"></div>

            <!-- Fields -->
            <div style="border-top:1px solid #e9ecef; padding-top:1rem;">
                <div
                    style="display:flex; justify-content:space-between; padding:0.75rem 0; border-bottom:1px solid #f0f0f0;">
                    <span style="font-weight:500; color:#6c757d;">Amount ₱:</span>
                    <span id="modal-amount" style="font-weight:600;"></span>
                </div>
                <div
                    style="display:flex; justify-content:space-between; padding:0.75rem 0; border-bottom:1px solid #f0f0f0;">
                    <span style="font-weight:500; color:#6c757d;">Date:</span>
                    <span id="modal-date" style="font-weight:600; color:#1e1e1e;"></span>
                </div>
                <div
                    style="display:flex; justify-content:space-between; padding:0.75rem 0; border-bottom:1px solid #f0f0f0;">
                    <span style="font-weight:500; color:#6c757d;">Time:</span>
                    <span id="modal-time" style="font-weight:600; color:#1e1e1e;"></span>
                </div>
                <div id="modal-notes-row" style="display:none; justify-content:space-between; padding:0.75rem 0;">
                    <span style="font-weight:500; color:#6c757d;">Notes:</span>
                    <span id="modal-notes" style="font-weight:600; color:#1e1e1e;"></span>
                </div>
            </div>

            <!-- Footer -->
            <div style="margin-top:1.5rem; text-align:right;">
                <button onclick="closeDetails()" style="
                    background:#e9ecef;
                    border:none;
                    color:#495057;
                    padding:0.5rem 1.5rem;
                    border-radius:2rem;
                    font-weight:500;
                    cursor:pointer;">
                    Close
                </button>
            </div>
        </div>
    </div>

    <script>
        function showDetails(id) {
            fetch('/Transactions/DetailsJson/' + id)
                .then(r => r.json())
                .then(d => {
                    document.getElementById('modal-description').textContent = d.description;
                    document.getElementById('modal-category').textContent = d.category;
                    document.getElementById('modal-date').textContent = d.date;
                    document.getElementById('modal-time').textContent = d.time;

                    const amount = document.getElementById('modal-amount');
                    amount.textContent = (d.isExpense ? '- ' : '+ ') + d.absAmount;
                    amount.style.color = d.isExpense ? '#dc3545' : '#27AA83';

                    document.getElementById('modal-badge').innerHTML = d.isExpense
                        ? '<span style="background:#dc3545;color:white;padding:0.25rem 1rem;border-radius:20px;font-size:0.8rem;font-weight:600;">Expense</span>'
                        : '<span style="background:#27AA83;color:white;padding:0.25rem 1rem;border-radius:20px;font-size:0.8rem;font-weight:600;">Income</span>';

                    const notesRow = document.getElementById('modal-notes-row');
                    if (d.notes) {
                        document.getElementById('modal-notes').textContent = d.notes;
                        notesRow.style.display = 'flex';
                    } else {
                        notesRow.style.display = 'none';
                    }

                    const modal = document.getElementById('detailsModal');
                    modal.style.display = 'flex';
                });
        }

        function closeDetails() {
            document.getElementById('detailsModal').style.display = 'none';
        }

        // Close when clicking backdrop
        document.getElementById('detailsModal').addEventListener('click', function (e) {
            if (e.target === this) closeDetails();
        });
    </script>
}