@using BaonTrackerPro.Models
@model FinanceDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var today = DateTime.Now.ToString("dddd, MMMM dd, yyyy");
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --bg: #f0f2f0;
        --surface: #ffffff;
        --surface-alt: #f7f8f7;
        --border: #e4e7e4;
        --text-primary: #1a1d1a;
        --text-secondary: #6b7280;
        --text-muted: #9ca3af;
        --accent: #1a9f6e;
        --accent-light: #e6f7f1;
        --accent-dark: #137a54;
        --danger: #e53e3e;
        --danger-light: #fff5f5;
        --income-color: #1a9f6e;
        --expense-color: #e53e3e;
        --radius-sm: 10px;
        --radius-md: 14px;
        --radius-lg: 18px;
        --font: 'DM Sans', sans-serif;
        --font-mono: 'DM Mono', monospace;
    }

    .dashboard-wrapper {
        max-width: 900px;
        margin: 0 auto;
        padding: 28px 20px 48px;
        font-family: var(--font);
        color: var(--text-primary);
    }

    /* Header */
    .dash-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
        gap: 16px;
    }
    .dash-header-left .section-label {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 2px;
    }
    .dash-header-left .date-text {
        font-size: 12px;
        color: var(--text-secondary);
        margin-bottom: 8px;
    }
    .dash-header-left h1 {
        font-size: 26px;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: -.3px;
    }
    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 10px 20px;
        font-family: var(--font);
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        transition: background .15s;
    }
    .btn-add:hover { background: var(--accent-dark); color: #fff; }

    /* Stat Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 16px;
    }
    @@media (max-width: 640px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .stat-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .stat-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--text-muted);
    }
    .stat-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .stat-icon.balance  { background: #e6f4ff; }
    .stat-icon.income   { background: var(--accent-light); }
    .stat-icon.expense  { background: #fff0f0; }
    .stat-icon.savings  { background: #fef3e2; }
    .stat-value {
        font-family: var(--font-mono);
        font-size: 20px;
        font-weight: 500;
        color: var(--text-primary);
    }

    /* Mid Grid */
    .mid-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }
    @@media (max-width: 580px) {
        .mid-grid { grid-template-columns: 1fr; }
    }
    .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 20px;
    }
    .card-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 16px;
    }

    /* Donut */
    .spending-inner { display: flex; align-items: center; gap: 20px; }
    .donut-wrap { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
    .cat-legend { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .cat-item { display: flex; align-items: center; gap: 6px; font-size: 13px; }
    .cat-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .cat-name { flex: 1; color: var(--text-secondary); }
    .cat-pct  { font-weight: 500; color: var(--text-primary); }

    /* Savings */
    .savings-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px 0;
        gap: 10px;
        color: var(--text-muted);
    }
    .savings-empty svg { opacity: .4; }
    .savings-empty p { font-size: 13px; }
    .goal-item { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .goal-header { display: flex; justify-content: space-between; font-size: 13px; }
    .goal-name { font-weight: 500; }
    .goal-amounts { color: var(--text-secondary); }
    .goal-bar { height: 6px; background: var(--bg); border-radius: 99px; overflow: hidden; }
    .goal-fill { height: 100%; background: var(--accent); border-radius: 99px; }
    .btn-add-goal {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        margin-top: 6px;
        font-size: 13px;
        font-weight: 500;
        color: var(--accent);
        background: none;
        border: none;
        cursor: pointer;
        font-family: var(--font);
    }

    /* Transactions */
    .txn-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px; }
    .txn-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .txn-header a { font-size: 13px; font-weight: 500; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 3px; }
    .txn-list { display: flex; flex-direction: column; gap: 2px; }
    .txn-item { display: flex; align-items: center; gap: 12px; padding: 10px 8px; border-radius: var(--radius-sm); transition: background .1s; }
    .txn-item:hover { background: var(--surface-alt); }
    .txn-avatar { width: 38px; height: 38px; border-radius: 10px; background: var(--surface-alt); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 17px; flex-shrink: 0; }
    .txn-info { flex: 1; min-width: 0; }
    .txn-name { font-size: 14px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .txn-meta { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
    .txn-amount { font-family: var(--font-mono); font-size: 14px; font-weight: 500; white-space: nowrap; display: flex; align-items: center; gap: 4px; }
    .txn-amount.income  { color: var(--income-color); }
    .txn-amount.expense { color: var(--expense-color); }

    /* Modal */
    .modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.35); z-index: 100; align-items: center; justify-content: center; }
    .modal-backdrop.open { display: flex; }
    .modal { background: var(--surface); border-radius: var(--radius-lg); padding: 28px; width: 100%; max-width: 420px; margin: 16px; }
    .modal-title { font-size: 17px; font-weight: 600; margin-bottom: 20px; }
    .form-group { margin-bottom: 14px; }
    .form-label { display: block; font-size: 12px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 5px; }
    .form-control { width: 100%; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-family: var(--font); font-size: 14px; color: var(--text-primary); background: var(--surface); outline: none; transition: border-color .15s; }
    .form-control:focus { border-color: var(--accent); }
    .type-toggle { display: flex; gap: 8px; margin-bottom: 14px; }
    .type-btn { flex: 1; padding: 8px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); font-family: var(--font); font-size: 13px; font-weight: 500; cursor: pointer; color: var(--text-secondary); transition: all .15s; }
    .type-btn.active-income  { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
    .type-btn.active-expense { background: var(--danger-light); border-color: var(--danger); color: var(--danger); }
    .modal-actions { display: flex; gap: 10px; margin-top: 20px; }
    .btn-cancel { flex: 1; padding: 10px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); font-family: var(--font); font-size: 14px; cursor: pointer; color: var(--text-secondary); }
    .btn-save { flex: 2; padding: 10px; border: none; border-radius: var(--radius-sm); background: var(--accent); color: #fff; font-family: var(--font); font-size: 14px; font-weight: 500; cursor: pointer; }
    .btn-save:hover { background: var(--accent-dark); }
</style>

<div class="dashboard-wrapper">

    <!-- Header -->
    <div class="dash-header">
        <div class="dash-header-left">
            <div class="section-label">Dashboard</div>
            <div class="date-text">@today</div>
            <h1>Good Day, @Model.UserName!</h1>
        </div>
        <button class="btn-add" onclick="document.getElementById('addModal').classList.add('open')">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 1v12M1 7h12" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Add Transaction
        </button>
    </div>

    <!-- Stat Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Balance</span>
                <span class="stat-icon balance">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <rect x="1" y="4" width="14" height="10" rx="2" stroke="#3b82f6" stroke-width="1.5"/>
                        <path d="M1 7h14" stroke="#3b82f6" stroke-width="1.5"/>
                        <rect x="3" y="9" width="3" height="2" rx=".5" fill="#3b82f6"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value">&#8369; @Model.Balance.ToString("N2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Income</span>
                <span class="stat-icon income">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3 11L8 5l5 6" stroke="#1a9f6e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value">&#8369; @Model.Income.ToString("N2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Expenses</span>
                <span class="stat-icon expense">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3 5l5 6 5-6" stroke="#e53e3e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value">&#8369; @Model.Expenses.ToString("N2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <span class="stat-label">Savings Goals</span>
                <span class="stat-icon savings">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <ellipse cx="8" cy="9" rx="6" ry="5" stroke="#f59e0b" stroke-width="1.5"/>
                        <path d="M5 5.5C5 4 6.5 2.5 8 2.5s3 1.5 3 3" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                        <path d="M10.5 8H14" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="12" cy="10" r=".75" fill="#f59e0b"/>
                    </svg>
                </span>
            </div>
            <div class="stat-value">&#8369; @Model.SavingsGoals.ToString("N2")</div>
        </div>
    </div>

    <!-- Mid: Spending + Savings -->
    <div class="mid-grid">
        <!-- Spending by Category -->
        <div class="card">
            <div class="card-title">Spending by Category</div>
            @if (Model.SpendingByCategory != null && Model.SpendingByCategory.Any())
            {
                <div class="spending-inner">
                    <div class="donut-wrap">
                        <canvas id="donutChart"></canvas>
                    </div>
                    <div class="cat-legend">
                        @foreach (var cat in Model.SpendingByCategory)
                        {
                            <div class="cat-item">
                                <span class="cat-dot" style="background: @cat.Color;"></span>
                                <span>@cat.Icon</span>
                                <span class="cat-name">@cat.Name</span>
                                <span class="cat-pct">@cat.Percentage.ToString("0")%</span>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="savings-empty">
                    <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                        <circle cx="24" cy="24" r="20" stroke="#9ca3af" stroke-width="2"/>
                        <path d="M16 24h16M24 16v16" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    <p>No spending data yet</p>
                </div>
            }
        </div>

        <!-- Savings Goals -->
        <div class="card">
            <div class="card-title">Savings Goals</div>
            @if (Model.Goals != null && Model.Goals.Any())
            {
                @foreach (var goal in Model.Goals)
                {
                    var pct = goal.TargetAmount > 0 ? (goal.CurrentAmount / goal.TargetAmount * 100) : 0;
                    <div class="goal-item">
                        <div class="goal-header">
                            <span class="goal-name">@goal.Name</span>
                            <span class="goal-amounts">&#8369;@goal.CurrentAmount.ToString("N0") / &#8369;@goal.TargetAmount.ToString("N0")</span>
                        </div>
                        <div class="goal-bar">
                            <div class="goal-fill" style="width: @pct.ToString("0")%;"></div>
                        </div>
                    </div>
                }
                <button class="btn-add-goal">+ Add Goal</button>
            }
            else
            {
                <div class="savings-empty">
                    <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
                        <ellipse cx="28" cy="34" rx="18" ry="15" stroke="#9ca3af" stroke-width="2"/>
                        <path d="M17 17.5C17 13 21.5 9 28 9s11 4 11 8.5" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                        <path d="M38 29H46" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="42" cy="34" r="2" fill="#9ca3af"/>
                        <path d="M24 34h8M28 30v8" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    <p>No Savings Goals yet</p>
                </div>
                <button class="btn-add-goal">+ Add Goal</button>
            }
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="txn-card">
        <div class="txn-header">
            <div class="card-title" style="margin-bottom:0;">Recent Transactions</div>
            <a href="/Transactions">View All
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
        </div>
        <div class="txn-list">
            @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
            {
                @foreach (var txn in Model.RecentTransactions)
                {
                    <div class="txn-item">
                        <div class="txn-avatar">@txn.CategoryIcon</div>
                        <div class="txn-info">
<div class="txn-name">@txn.Description</div>                            <div class="txn-meta">@txn.Category · @txn.Date.ToString("MMM dd")</div>
                        </div>
                        <div class="txn-amount @(txn.IsIncome ? "income" : "expense")">
                            @if (txn.IsIncome)
                            {
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                    <path d="M2 8L6 3l4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span>+ &#8369;@txn.Amount.ToString("N2")</span>
                            }
                            else
                            {
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                    <path d="M2 4l4 5 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span>- &#8369;@txn.Amount.ToString("N2")</span>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="savings-empty">
                    <p>No transactions yet</p>
                </div>
            }
        </div>
    </div>

</div>

<!-- Add Transaction Modal -->
<div class="modal-backdrop" id="addModal" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal">
        <div class="modal-title">Add Transaction</div>
        <div class="type-toggle">
            <button class="type-btn active-expense" id="typeExpense" onclick="setType('expense')">Expense</button>
            <button class="type-btn" id="typeIncome" onclick="setType('income')">Income</button>
        </div>
        @using (Html.BeginForm("AddTransaction", "Home", FormMethod.Post, new { id = "txnForm" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="IsIncome" id="isIncomeField" value="false" />
            <div class="form-group">
                <label class="form-label">Description</label>
                <input name="Description" class="form-control" placeholder="e.g. Mga damit" required />            </div>
            <div class="form-group">
                <label class="form-label">Amount (&#8369;)</label>
                <input name="Amount" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" required />
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <select name="Category" class="form-control">
                    <option value="Personal/Lifestyle">🛍 Personal/Lifestyle</option>
                    <option value="Transportation">🚌 Transportation</option>
                    <option value="Food">🍔 Food</option>
                    <option value="Allowance">💵 Allowance</option>
                    <option value="Bills">🧾 Bills</option>
                    <option value="Health">💊 Health</option>
                    <option value="Entertainment">🎮 Entertainment</option>
                    <option value="Others">📦 Others</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Date</label>
                <input name="Date" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="document.getElementById('addModal').classList.remove('open')">Cancel</button>
                <button type="submit" class="btn-save">Save Transaction</button>
            </div>
        }
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
    var donutCanvas = document.getElementById('donutChart');
    if (donutCanvas) {
        var catData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            Model.SpendingByCategory != null
                ? Model.SpendingByCategory.Select(c => new { label = c.Name, value = c.Percentage, color = c.Color })
                : Enumerable.Empty<object>()
        ));
        if (catData && catData.length > 0) {
            new Chart(donutCanvas, {
                type: 'doughnut',
                data: {
                    labels: catData.map(c => c.label),
                    datasets: [{
                        data: catData.map(c => c.value),
                        backgroundColor: catData.map(c => c.color),
                        borderWidth: 3,
                        borderColor: '#fff',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    cutout: '68%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: ctx => ' ' + ctx.label + ': ' + ctx.parsed + '%' } }
                    }
                }
            });
        }
    }

    function setType(type) {
        var isIncome = type === 'income';
        document.getElementById('isIncomeField').value = isIncome;
        document.getElementById('typeIncome').className  = 'type-btn' + (isIncome ? ' active-income' : '');
        document.getElementById('typeExpense').className = 'type-btn' + (!isIncome ? ' active-expense' : '');
    }
</script>
